# ============================
# SupportForge API — Environment Configuration
# ============================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ============================
# Application
# ============================
APP_NAME=SupportForge
APP_ENV=development                    # development | staging | production | test | testing
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=DEBUG                    # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-to-a-random-secret-key

# ============================
# Ollama (Self-Hosted LLM)
# ============================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma3:4b                # Chat model (available: gemma3:4b, qwen3:4b)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text   # Nomic Embed Text (137M, F16)

# Cloudflare Access Service Token (required for Ollama access)
CF_OLLAMA_ID=                          # CF-Access-Client-Id
CF_OLLAMA_SECRET=                      # CF-Access-Client-Secret

# ============================
# PostgreSQL
# ============================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=supportforge
POSTGRES_USER=supportforge
POSTGRES_PASSWORD=change-me

# Async connection string (leave empty to auto-compute from components above)
DATABASE_URL=

# ============================
# Redis
# ============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=                             # Leave empty to auto-compute from components above

# ============================
# ChromaDB
# ============================
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_PREFIX=tenant_       # Collections namespaced as tenant_{id}

# ============================
# Ingestion Pipeline
# ============================
INGESTION_MAX_CONCURRENT=2             # Max documents processed simultaneously (default: 2)

# ============================
# Retrieval Pipeline
# ============================
BM25_ENABLED=true                      # Enable BM25 keyword search alongside vector (default: true)
RERANKER_ENABLED=false                 # Enable cross-encoder reranker (needs pip install -e ".[reranker]")
RETRIEVAL_K_PER_METHOD=20              # Candidates retrieved per method (default: 20)
RETRIEVAL_FINAL_K=5                    # Final chunks sent to LLM prompt (default: 5)
RETRIEVAL_RRF_K=60                     # RRF smoothing constant (default: 60, must be >= 1)
RETRIEVAL_VECTOR_WEIGHT=0.5            # Vector search priority in fusion (0.0–1.0, default: 0.5)
RETRIEVAL_BM25_WEIGHT=0.5             # BM25 search priority in fusion (0.0–1.0, default: 0.5)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2  # Cross-encoder model (default)

# ============================
# Conversation History
# ============================
HISTORY_SUMMARIZE_THRESHOLD=10         # User-assistant pairs before history is summarized (default: 10)

# ============================
# JWT Authentication
# ============================
JWT_SECRET_KEY=change-me-to-another-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================
# Rate Limiting
# ============================
RATE_LIMIT_PER_USER=60                 # requests per minute per user
RATE_LIMIT_PER_TENANT=1000             # requests per minute per tenant

# ============================
# Email (Phase 4 — Email Digest)
# ============================
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@supportforge.dev

# ============================
# Superadmin Bootstrap (optional)
# ============================
# If both are set, the app auto-creates a "management" tenant and
# superadmin user on every startup (idempotent — skips if exists).
# Leave empty to disable auto-bootstrap and use scripts/create_superadmin.py instead.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# ============================
# CORS
# ============================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
